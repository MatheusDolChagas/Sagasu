# Copie para .env.local e preencha com o projeto Supabase (Storage > buckets)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon
# Idêntico ao nome do bucket no painel (ex.: SIGHTINGS)
# VITE_SUPABASE_SIGHTINGS_BUCKET=SIGHTINGS
# Fotos de casos e avatares (crie no Supabase Storage + políticas públicas de leitura)
# VITE_SUPABASE_CASES_BUCKET=cases
# VITE_SUPABASE_AVATARS_BUCKET=avatars
