// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuário do sistema
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  phone         String?
  avatarUrl     String?
  role          UserRole @default(USER)
  isActive      Boolean  @default(true)
  // Conta pública: false até confirmar email pelo link
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?   @unique
  emailVerificationExpires   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  cases         Case[]
  tips          Tip[]
  volunteers    Volunteer[]
  notifications Notification[]
  groups        Group[]
  groupMembers      GroupMember[]
  groupComments     GroupComment[]
  groupReadReceipts GroupReadReceipt[]
  sightings         Sighting[]

  @@map("users")
}

enum UserRole {
  USER
  POLICE
  NGO
  ADMIN
}

// Caso de desaparecimento
model Case {
  id              String      @id @default(uuid())
  title           String
  description     String      @db.Text
  missingPersonName String
  age             Int?
  gender          String?
  lastSeenLocation String?
  lastSeenLatitude  Float?
  lastSeenLongitude Float?
  lastSeenDate    DateTime?
  status          CaseStatus  @default(ACTIVE)
  isVerified      Boolean     @default(false)
  closureDetails  String?     @db.Text
  cancellationReason String?  @db.Text
  closedAt        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relacionamentos
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tips            Tip[]
  volunteers      Volunteer[]
  groups          Group[]
  media           Media[]
  notifications   Notification[]
  sightings       Sighting[]

  @@map("cases")
}

enum CaseStatus {
  ACTIVE
  FOUND
  CLOSED
  ARCHIVED
}

// Dica/Informação anônima ou identificada
model Tip {
  id          String      @id @default(uuid())
  content     String      @db.Text
  location    String?
  latitude    Float?
  longitude   Float?
  isAnonymous Boolean     @default(true)
  isVerified  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relacionamentos
  caseId      String
  case        Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  media       Media[]

  @@map("tips")
}

// Avistamento com foto e localização (relatado por usuários)
model Sighting {
  id          String   @id @default(uuid())
  description String?  @db.Text
  latitude    Float
  longitude   Float
  photoUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("sightings")
}

// Voluntário individual
model Volunteer {
  id          String   @id @default(uuid())
  status      VolunteerStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([userId, caseId])
  @@map("volunteers")
}

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
}

// Grupo de busca (ONG)
model Group {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  leaderId    String
  leader      User     @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  members       GroupMember[]
  comments      GroupComment[]
  readReceipts  GroupReadReceipt[]
  notifications Notification[]

  @@map("groups")
}

// Controle de mensagens lidas por usuário em cada grupo/contato
model GroupReadReceipt {
  id         String   @id @default(uuid())
  lastReadAt DateTime @default(now())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_read_receipts")
}

// Membros do grupo
model GroupMember {
  id          String   @id @default(uuid())
  role        GroupRole @default(MEMBER)
  joinedAt    DateTime @default(now())

  // Relacionamentos
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupRole {
  LEADER
  MEMBER
}

model GroupComment {
  id        String   @id @default(uuid())
  content   String?  @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())

  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("group_comments")
}

// Mídia (fotos, vídeos)
model Media {
  id          String   @id @default(uuid())
  url         String
  type        MediaType
  isVerified  Boolean  @default(false)
  aiAnalysis  String?  @db.Text
  createdAt   DateTime @default(now())

  // Relacionamentos
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tipId       String?
  tip         Tip?     @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@map("media")
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

// Notificações
model Notification {
  id          String   @id @default(uuid())
  title       String
  message     String   @db.Text
  type        NotificationType
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Relacionamentos
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  TIP_RECEIVED
  CASE_UPDATE
  VOLUNTEER_JOINED
  CASE_RESOLVED
  GROUP_MESSAGE
  SYSTEM
}

// Mensagens do formulário de contato (site)
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
