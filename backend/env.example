# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sagasu?schema=public"

# JWT
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000

# Email de confirmação de cadastro (obrigatório em produção)
# Opção A — Resend (recomendado): https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Opção B — SMTP (Gmail, Outlook, Brevo, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=senha-de-app-do-gmail
# EMAIL_FROM=Sagasu <seu-email@gmail.com>

# External APIs
OPENAI_API_KEY=your-openai-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
WHATSAPP_API_KEY=your-whatsapp-api-key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
